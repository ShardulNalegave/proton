
let mut name = "Shardul";
let age = 19_u8;

let greet = fn() str {
  "Hello, ${name}"
};

let greet2 = fn() str => "Hello, ${name}";

let AppState = struct {
  score: uint,
  incrementScore: fn(&mut self) {
    self.score += 1;
  },
};

let Status = enum {
  Pending,
  InProgress,
  Done,
};

let Animal = interface {
  speak: fn() void,
};

let Dog: type = struct {
  //sdngfh
};

impl Animal for Dog {
  speak: fn() => print("Bark!"),
};

let Option = enum<T> {
  Some(T),
  None,
};